{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],

    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.mts",
    "../dist/**/*.d.mts"
  ]
}